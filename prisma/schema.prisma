generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum LabStatus {
  NORMAL
  REVIEW_NEEDED
}

enum MetricStatus {
  NORMAL
  HIGH
  LOW
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CaseStatus {
  OPEN
  AI_PRE_SCREENED
  UNDER_REVIEW
  OPINION_READY
  CLOSED
  DISPUTED
}

enum OpinionStatus {
  DRAFT
  SIGNED
  DELIVERED
  DISPUTED
}

enum ServiceType {
  SPECIALIST_OPINION
  RESULT_INTERPRETATION
  FOLLOW_UP
  TREND_ANALYSIS
}

model User {
  id         String   @id @default(cuid())
  name       String?
  email      String   @unique
  emailVerified DateTime?
  image      String?
  passwordHash String?
  role       Role     @default(PATIENT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  doctorProfile     Doctor?
  patientAppointments Appointment[] @relation("PatientAppointments")
  labResults        LabResult[]
  posts             Post[]
  cases             Case[]         @relation("PatientCases")
  specialistCases   Case[]         @relation("SpecialistCases")
  specialistOpinions SpecialistOpinion[]
  auditLogs         AuditLog[]
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  category    String?
  tags        String[]
  authorId    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Doctor {
  id            String   @id @default(cuid())
  userId        String   @unique
  specialty     String
  experience    String
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  locationType  String   @default("Telehealth & In-person")
  bio           String?
  imageUrl      String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  services      DoctorService[]
  appointments  Appointment[]     @relation("DoctorAppointments")
}

model DoctorService {
  id          String   @id @default(cuid())
  doctorId    String
  title       String
  description String?
  price       Float
  createdAt   DateTime @default(now())

  doctor      Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Service {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  category    String
}

model LabResult {
  id        String   @id @default(cuid())
  patientId String
  name      String
  date      DateTime
  doctor    String
  status    LabStatus @default(NORMAL)
  icon      String
  aiInterpretation String?
  createdAt DateTime @default(now())

  patient User        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  metrics LabMetric[]
  trends  LabTrendPoint[]
}

model LabMetric {
  id             String       @id @default(cuid())
  labResultId    String
  name           String
  referenceRange String
  value          Float
  unit           String
  status         MetricStatus @default(NORMAL)

  labResult LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)
}

model LabTrendPoint {
  id          String @id @default(cuid())
  labResultId String
  date        String
  value       Float

  labResult LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)
}

model Appointment {
  id         String             @id @default(cuid())
  patientId  String
  doctorId   String
  date       DateTime
  time       String
  status     AppointmentStatus  @default(SCHEDULED)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  patient User   @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
}

model Case {
  id           String             @id @default(cuid())
  patientId    String
  specialistId String?
  serviceType  ServiceType
  status       CaseStatus         @default(OPEN)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  patient      User               @relation("PatientCases", fields: [patientId], references: [id], onDelete: Cascade)
  specialist   User?              @relation("SpecialistCases", fields: [specialistId], references: [id], onDelete: SetNull)
  records      CaseRecord[]
  opinions     SpecialistOpinion[]
  aiPrescreens AIPrescreen[]
}

model CaseRecord {
  id         String   @id @default(cuid())
  caseId     String
  fileUrl    String
  fileType   String
  fileName   String
  uploadedAt DateTime @default(now())

  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model SpecialistOpinion {
  id           String               @id @default(cuid())
  caseId       String
  specialistId String
  content      String
  status       OpinionStatus        @default(DRAFT)
  signedAt     DateTime?
  createdAt    DateTime             @default(now())

  case         Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  specialist   User                 @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  plainSummary PlainLanguageSummary?
  followUps    FollowUpQuestion[]
}

model AIPrescreen {
  id           String   @id @default(cuid())
  caseId       String
  findings     String
  differentials String?
  urgentFlags  String?
  generatedAt  DateTime @default(now())

  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model PlainLanguageSummary {
  id          String   @id @default(cuid())
  opinionId   String   @unique
  content     String
  generatedAt DateTime @default(now())

  opinion     SpecialistOpinion @relation(fields: [opinionId], references: [id], onDelete: Cascade)
}

model FollowUpQuestion {
  id        String   @id @default(cuid())
  opinionId String
  question  String
  answer    String
  scopeNote String?
  createdAt DateTime @default(now())

  opinion   SpecialistOpinion @relation(fields: [opinionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  timestamp    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
