{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "command": {
    "dev": {
      "description": "Start the Next.js dev server",
      "template": "Run the development server with `npm run dev`"
    },
    "build": {
      "description": "Build the Next.js project",
      "template": "Build the project with `npm run build`"
    },
    "lint": {
      "description": "Run ESLint checks",
      "template": "Run linting with `npm run lint`"
    }
  }
}
